# --- Solana cluster ---
# Flip between clusters with one variable. RPC_URL is optional —
# if omitted, the public endpoint for the cluster is used automatically.
#
#   devnet         → https://api.devnet.solana.com
#   mainnet-beta   → https://api.mainnet-beta.solana.com
#
CLUSTER=devnet
# RPC_URL=                          # Optional override (Helius, Triton, etc.)

# --- Keeper wallet ---
# Path to the JSON keypair file. For local dev, point at your existing
# Solana CLI keypair; for staging/prod use a dedicated keypair (and in
# real production, an HSM / Squads-signed transaction flow).
KEEPER_KEYPAIR_PATH=./keeper-keypair.json

# --- Redis ---
# Paste the connection URL for your Redis instance.
# Redis Cloud / Upstash:  rediss://default:<token>@<host>:<port>
# Local:                  redis://localhost:6379
REDIS_URL=redis://localhost:6379

# --- Scheduler ---
# How often the keeper polls Redis for due savings configs (milliseconds).
# Default: 60000 (1 minute). Minimum recommended: 10000 (10 seconds).
SCHEDULER_POLL_INTERVAL_MS=60000

# --- Telegram notifications ---
# Bot API token from @BotFather. Optional — notifications are skipped if absent.
# The Telegram user ID is read from each user's `wallet:telegram:<id>` Redis key.
TELEGRAM_BOT_TOKEN=

# --- Logging ---
LOG_LEVEL=info
